# Copy to .env.staging (gitignored), fill Supabase + API URLs, then:
#   npm run setup:github-e2e-secrets
#
# Also used by npm run configure:contact-env for local + dashboard reference.

CONTACT_EMAIL=hello@crenit.co

# --- GitHub Actions (repository secrets) ---
E2E_TENANT_EMAIL=tenant@rentcredit.demo
E2E_TENANT_PASSWORD=DemoTenant123!
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_API_URL=https://crenit-api.onrender.com

# --- Render (API) — set in Render dashboard Environment ---
# EMAIL_CONTACT=hello@crenit.co
# EMAIL_REPLY_TO=hello@crenit.co

# --- Vercel (web) — set in Vercel project Environment Variables ---
# NEXT_PUBLIC_CONTACT_EMAIL=hello@crenit.co
