# Copy to .env in repo root (never commit .env)

NODE_ENV=development
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
JWT_SECRET=generate-at-least-32-random-characters-for-production
PORT=3001
CORS_ORIGIN=http://localhost:3002
# Production: https://your-app.vercel.app (comma-separate preview + production URLs)
WEB_URL=http://localhost:3002
APP_URL=http://localhost:3002
ADMIN_EMAILS=admin@yourdomain.com
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
MAX_KYC_UPLOAD_BYTES=8388608

# --- Email ---
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=CRENIT <your@gmail.com>
EMAIL_REPLY_TO=robertofeijon@mail.com
EMAIL_CONTACT=robertofeijon@mail.com

# Resend alternative:
# EMAIL_PROVIDER=resend
# EMAIL_PROVIDER_API_KEY=re_...

# --- 2FA (staging/production) ---
# TWO_FACTOR_ENFORCEMENT=true
# ADMIN_REQUIRE_2FA=true
# LANDLORD_REQUIRE_2FA=false
# TWO_FACTOR_SESSION_HOURS=12

# --- External cron (Render/cron-job.org) — POST /internal/cron/:job with header X-Cron-Secret ---
# CRON_SECRET=long-random-secret

# --- Payments (required when webhooks are live) ---
# PAYMENT_WEBHOOK_SECRET=long-random-secret
# MAX_EFT_PROOF_UPLOAD_BYTES=5242880

# --- Observability (optional) ---
# SENTRY_DSN=https://...@sentry.io/...
# SENTRY_ENVIRONMENT=staging

# --- Playwright login E2E (CI secrets; demo: tenant@rentcredit.demo / DemoTenant123!) ---
# E2E_TENANT_EMAIL=tenant@rentcredit.demo
# E2E_TENANT_PASSWORD=DemoTenant123!

# --- SMS (optional) ---
# SMS_ENABLED=false
